              <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:6px;">
                <p style="margin:0;font-size:.82rem;color:#f5d0fe;font-weight:600;">Ketua Divisi KOMINFO</p>
                <span style="background:rgba(255,255,255,0.15);color:white;border-radius:20px;padding:3px 10px;font-size:.74rem;font-weight:600;">Jul 2023 – Jul 2024</span>
